rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development rules: open access for this portal while backend is being integrated.
    // Tighten these before production deployment.
    match /students/{rollNo} {
      allow read, write: if true;
    }

    match /results/{rollNo} {
      allow read, write: if true;
    }
  }
}
